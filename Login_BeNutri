```
    <form class="login-form" id="loginForm">
        <div class="error-message" id="errorMessage"></div>
        <div class="success-message" id="successMessage"></div>
        
        <div class="form-group">
            <label for="email">Correo Electrónico</label>
            <input type="email" id="email" name="email" placeholder="ejemplo@benutri.com" required>
        </div>
        
        <div class="form-group">
            <label for="password">Contraseña</label>
            <input type="password" id="password" name="password" placeholder="Tu contraseña segura" required>
            <span class="password-toggle" onclick="togglePassword()">👁️</span>
        </div>
        
        <button type="submit" class="login-btn">Iniciar Sesión</button>
        
        <div class="forgot-password">
            <a href="#" onclick="forgotPassword()">¿Olvidaste tu contraseña?</a>
        </div>
        
        <div class="register-link">
            ¿No tienes cuenta? <a href="#" onclick="showRegister()">Regístrate aquí</a>
        </div>
    </form>
</div>

<script>
    // Variables globales
    const loginForm = document.getElementById('loginForm');
    const errorMessage = document.getElementById('errorMessage');
    const successMessage = document.getElementById('successMessage');
    const emailInput = document.getElementById('email');
    const passwordInput = document.getElementById('password');

    // Usuarios demo para testing
    const demoUsers = [
        { email: 'admin@benutri.com', password: 'admin123', role: 'admin' },
        { email: 'nutricionista@benutri.com', password: 'nutri123', role: 'nutritionist' },
        { email: 'usuario@benutri.com', password: 'user123', role: 'user' }
    ];

    // Función para mostrar/ocultar contraseña
    function togglePassword() {
        const passwordField = document.getElementById('password');
        const toggle = document.querySelector('.password-toggle');
        
        if (passwordField.type === 'password') {
            passwordField.type = 'text';
            toggle.textContent = '🙈';
        } else {
            passwordField.type = 'password';
            toggle.textContent = '👁️';
        }
    }

    // Función para mostrar mensajes
    function showMessage(message, type = 'error') {
        hideMessages();
        
        if (type === 'error') {
            errorMessage.textContent = message;
            errorMessage.style.display = 'block';
        } else {
            successMessage.textContent = message;
            successMessage.style.display = 'block';
        }
    }

    // Función para ocultar mensajes
    function hideMessages() {
        errorMessage.style.display = 'none';
        successMessage.style.display = 'none';
    }

    // Función para validar email
    function validateEmail(email) {
        const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
        return emailRegex.test(email);
    }

    // Función para validar formulario
    function validateForm(email, password) {
        if (!email || !password) {
            showMessage('Por favor, completa todos los campos');
            return false;
        }
        
        if (!validateEmail(email)) {
            showMessage('Por favor, ingresa un correo electrónico válido');
            return false;
        }
        
        if (password.length < 6) {
            showMessage('La contraseña debe tener al menos 6 caracteres');
            return false;
        }
        
        return true;
    }

    // Función para autenticar usuario
    function authenticateUser(email, password) {
        // Simular autenticación con usuarios demo
        const user = demoUsers.find(u => u.email === email && u.password === password);
        
        if (user) {
            return {
                success: true,
                user: {
                    email: user.email,
                    role: user.role,
                    name: user.email.split('@')[0]
                }
            };
        }
        
        return {
            success: false,
            message: 'Credenciales incorrectas'
        };
    }

    // Función para manejar login exitoso
    function handleSuccessfulLogin(user) {
        showMessage(`¡Bienvenido ${user.name}! Redirigiendo...`, 'success');
        
        // Guardar datos de usuario (en un proyecto real usarías JWT)
        const userData = {
            email: user.email,
            role: user.role,
            name: user.name,
            loginTime: new Date().toISOString()
        };
        
        // Simular guardado en localStorage
        localStorage.setItem('benutri_user', JSON.stringify(userData));
        
        // Simular redirección después de 2 segundos
        setTimeout(() => {
            alert(`Sesión iniciada exitosamente como ${user.role}\nEn un proyecto real, serías redirigido al dashboard.`);
            
            // Aquí irías al dashboard
            // window.location.href = '/dashboard';
        }, 2000);
    }

    // Event listener para el formulario
    loginForm.addEventListener('submit', async function(e) {
        e.preventDefault();
        
        const email = emailInput.value.trim();
        const password = passwordInput.value;
        
        // Validar formulario
        if (!validateForm(email, password)) {
            return;
        }
        
        // Mostrar estado de carga
        loginForm.classList.add('loading');
        hideMessages();
        
        try {
            // Simular delay de red
            await new Promise(resolve => setTimeout(resolve, 1000));
            
            // Autenticar usuario
            const result = authenticateUser(email, password);
            
            if (result.success) {
                handleSuccessfulLogin(result.user);
            } else {
                showMessage(result.message);
            }
            
        } catch (error) {
            showMessage('Error de conexión. Inténtalo de nuevo.');
        } finally {
            loginForm.classList.remove('loading');
        }
    });

    // Función para recuperar contraseña
    function forgotPassword() {
        const email = prompt('Ingresa tu correo electrónico:');
        if (email && validateEmail(email)) {
            showMessage('Se ha enviado un enlace de recuperación a tu correo', 'success');
        } else if (email) {
            showMessage('Por favor, ingresa un correo válido');
        }
    }

    // Función para mostrar registro
    function showRegister() {
        alert('En un proyecto completo, esto te llevaría a la página de registro.\n\nUsuarios demo para probar:\n• admin@benutri.com / admin123\n• nutricionista@benutri.com / nutri123\n• usuario@benutri.com / user123');
    }

    // Inicialización
    document.addEventListener('DOMContentLoaded', function() {
        // Verificar si ya hay una sesión activa
        const savedUser = localStorage.getItem('benutri_user');
        if (savedUser) {
            const userData = JSON.parse(savedUser);
            showMessage(`Ya tienes una sesión activa como ${userData.name}`, 'success');
        }
        
        // Focus en el campo de email
        emailInput.focus();
        
        // Limpiar mensajes al escribir
        [emailInput, passwordInput].forEach(input => {
            input.addEventListener('input', hideMessages);
        });
    });

    // Funciones adicionales para demostración
    function logout() {
        localStorage.removeItem('benutri_user');
        showMessage('Sesión cerrada exitosamente', 'success');
        setTimeout(() => {
            location.reload();
        }, 1500);
    }

    // Exponer función logout globalmente para testing
    window.logout = logout;
</script>
